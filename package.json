{
  "name": "oculauncher",
  "version": "1.0.1",
  "description": "OcuLauncher — il launcher ufficiale di Oculandia VR: installa e avvia Minecraft con tutte le mod giuste, automaticamente.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64 --arm64",
    "dist:mac": "electron-builder --mac --x64 --arm64"
  },
  "author": "Oculandia VR",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "extract-zip": "^2.0.1",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "tar": "^7.5.21"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  },
  "homepage": "https://minecraft.oculandiavr.it",
  "repository": {
    "type": "git",
    "url": "https://github.com/xcapsa/OcuLauncher.git"
  }
}
